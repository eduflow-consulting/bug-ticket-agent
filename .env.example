# Next.js Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# n8n Webhooks
NEXT_PUBLIC_N8N_BASE_URL=https://n8n.example.com
N8N_WEBHOOK_SECRET=your_webhook_secret_here
N8N_API_KEY=your_n8n_api_key_here

# Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=RS256
JWT_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# Jira Integration
JIRA_HOST=https://your-company.atlassian.net
JIRA_USERNAME=your_jira_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=BUG

# AWS S3 (or Vercel Blob)
NEXT_PUBLIC_S3_REGION=eu-central-1
S3_BUCKET_NAME=bug-ticket-agent-uploads
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_chars_minimum

# Monitoring & Logging
SENTRY_DSN=https://your-key@sentry.io/your-project-id
DATADOG_API_KEY=your_datadog_api_key_here

# LLM Provider
OPENAI_API_KEY=sk-your-openai-key-here
CLAUDE_API_KEY=sk-ant-your-claude-key-here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
